; == BIBLIOTECA DE MACROS ==
; HARO CANDELARIO FERNANDO SAUL
;_______________________________

CURSOR MACRO REN,COL,PAG
    MOV AH,2
    MOV DH,REN
    MOV DL,COL
    MOV BH,PAG
    INT 10H
CURSOR ENDM            

IMP_CAD_SINCOLOR MACRO CADENA
    MOV AH,9
    LEA DX,CADENA
    INT 21H
IMP_CAD_SINCOLOR ENDM

RASTREO MACRO
    MOV AH,0            
    INT 16H            
RASTREO ENDM                            

IMPRESION MACRO CARACTER
    MOV AH,5
    MOV DL,CARACTER
    INT 21H
IMPRESION ENDM

NEWPAGE MACRO
    MOV AH,5
    MOV DL,12
    INT 21H
NEWPAGE ENDM

CREAR_CARPETA MACRO RUTA
        MOV AH,39H
        LEA DX,RUTA
        INT 21H
CREAR_CARPETA ENDM

CREAR_ARCHIVO MACRO RUTA,MODO
        MOV AH,3CH
        LEA DX,RUTA
        MOV CX,MODO ;32 ARCHIVO DE USUARIO
        INT 21H
            MOV ID,AX ;RECUPERAR ID
CREAR_ARCHIVO ENDM                                  

ABRIR_ARCHIVO MACRO RUTA,MODO
   ;MODOS DE APERTURA
   ; 0-Solo lectura
   ; 1-Solo escritura
   ; 2-Lectura/escritura
   MOV AH,3DH
   LEA DX,RUTA
   MOV AL,MODO 
   INT 21H   
ABRIR_ARCHIVO ENDM

ESCRIBIR_ARCHIVO MACRO ID,LONGITUD,DATOS
    MOV AH,40H
    MOV BX,ID
    MOV CX,LONGITUD
    LEA DX,DATOS
    INT 21H
ESCRIBIR_ARCHIVO ENDM

LEER_ARCHIVO MACRO ID,CUANTOS,DATOSLEIDOS
    MOV AH,3FH
    MOV BX,ID
    MOV CX,CUANTOS          
    LEA DX,DATOSLEIDOS
    MOV BX,ID
    INT 21H
LEER_ARCHIVO ENDM

CERRAR_ARCHIVO MACRO ID
    MOV AH,3EH
    MOV BX,ID
    INT 21H
CERRAR_ARCHIVO ENDM    

;_______________________________