; == BIBLIOTECA DE MACROS ==
; ATLANTIC CORP
;_______________________________

    enca1       db '    ___   __  __            __  _                              '
    enca2       db '   /   | / /_/ /___ _____  / /_(_)____   _________  _________  '
    enca3       db '  / /| |/ __/ / __ `/ __ \/ __/ / ___/  / ___/ __ \/ ___/ __ \ '
    enca4       db ' / ___ / /_/ / /_/ / / / / /_/ / /__   / /__/ /_/ / /  / /_/ / '
    enca5       db '/_/  |_\__/_/\__,_/_/ /_/\__/_/\___/   \___/\____/_/  / .___(_)'
    enca6       db '                                                     /_/       '
    
    p1 db ' \|/ '
    p2 db '--X--'
    p3 db ' /|\ '
    p4 db '[___]'

                     
     imp_color macro msj, long, fil, col 
        mov ah, 19
        lea bp, msj
        mov cx, long
        mov dh, fil
        mov dl, col
        mov bh, 0
        mov al, 0
        mov bl, 21h
        int 10h
           
     imp_color endm
     
     encabezado macro
        imp_color enca1, 63, 0, 0
        imp_color enca2, 63, 1, 0
        imp_color enca3, 63, 2, 0
        imp_color enca4, 63, 3, 0
        imp_color enca5, 63, 4, 0
        imp_color enca6, 63, 5, 0
        
        imp_color p1, 5, 0, 65
        imp_color p2, 5, 1, 65
        imp_color p3, 5, 2, 65
        imp_color p4, 5, 3, 65   
     encabezado endm

CURSOR MACRO REN,COL,PAG
    MOV AH,2
    MOV DH,REN
    MOV DL,COL
    MOV BH,PAG
    INT 10H
CURSOR ENDM            

IMP_CAD_SINCOLOR MACRO CADENA
    MOV AH,9
    LEA DX,CADENA
    INT 21H
IMP_CAD_SINCOLOR ENDM

RASTREO MACRO
    MOV AH,0            
    INT 16H            
RASTREO ENDM                            

IMPRESION MACRO CARACTER
    MOV AH,5
    MOV DL,CARACTER
    INT 21H
IMPRESION ENDM

NEWPAGE MACRO
    MOV AH,5
    MOV DL,12
    INT 21H
NEWPAGE ENDM

CREAR_CARPETA MACRO RUTA
        MOV AH,39H
        LEA DX,RUTA
        INT 21H
CREAR_CARPETA ENDM

CREAR_ARCHIVO MACRO RUTA,MODO
        MOV AH,3CH
        LEA DX,RUTA
        MOV CX,MODO ;32 ARCHIVO DE USUARIO
        INT 21H
            MOV ID,AX ;RECUPERAR ID
CREAR_ARCHIVO ENDM                                  

ABRIR_ARCHIVO MACRO RUTA,MODO
   ;MODOS DE APERTURA
   ; 0-Solo lectura
   ; 1-Solo escritura
   ; 2-Lectura/escritura
   MOV AH,3DH
   LEA DX,RUTA
   MOV AL,MODO 
   INT 21H   
ABRIR_ARCHIVO ENDM

ESCRIBIR_ARCHIVO MACRO ID,LONGITUD,DATOS
    MOV AH,40H
    MOV BX,ID
    MOV CX,LONGITUD
    LEA DX,DATOS
    INT 21H
ESCRIBIR_ARCHIVO ENDM

LEER_ARCHIVO MACRO ID,CUANTOS,DATOSLEIDOS
    MOV AH,3FH
    MOV BX,ID
    MOV CX,CUANTOS          
    LEA DX,DATOSLEIDOS
    MOV BX,ID
    INT 21H
LEER_ARCHIVO ENDM

CERRAR_ARCHIVO MACRO ID
    MOV AH,3EH
    MOV BX,ID
    INT 21H
CERRAR_ARCHIVO ENDM    

;_______________________________
